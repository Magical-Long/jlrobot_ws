<?xml version="1.0"?>
<robot name="iiwa7">

  <!--
    这是用于 Pinocchio / robot_state_publisher / RViz 的主 URDF。
    这里重点保留：
    1. 七轴机械臂的 link / joint 拓扑；
    2. 关节限位；
    3. 末端固定 frame `iiwa_link_ee`。
  -->

  <!-- materials -->
  <material name="Grey">
    <color rgba="0.7 0.7 0.7 1.0"/>
  </material>
  <material name="Orange">
    <color rgba="1.0 0.42 0.04 1.0"/>
  </material>

  <!-- base link：机械臂固定基座。 -->
  <link name="iiwa_link_0">
    <inertial>
      <origin xyz="-0.1 0 0.07"/>
      <mass value="5"/>
      <inertia ixx="0.05" iyy="0.06" izz="0.03" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://robot_description/meshes/visual/link_0.stl"/>
      </geometry>
      <material name="Grey"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://robot_description/meshes/collision/link_0.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- 七个转动关节按串联方式依次连接。 -->
  <!-- joint 1 -->
  <joint name="iiwa_joint_1" type="revolute">
    <parent link="iiwa_link_0"/>
    <child link="iiwa_link_1"/>
    <origin xyz="0 0 0.15"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.967" upper="2.967" effort="300" velocity="10"/>
  </joint>

  <link name="iiwa_link_1">
    <!--
      这里补齐动力学建模所需的惯性参数。
      参数来源与 `robot_gazebo_effort.urdf` 保持一致，
      这样 Pinocchio / inverse dynamics 与 Gazebo effort 模型使用同一套质量分布。
    -->
    <inertial>
      <origin xyz="0 -0.03 0.12" rpy="0 0 0"/>
      <mass value="3.4525"/>
      <inertia ixx="0.02183" ixy="0" ixz="0" iyy="0.007703" iyz="-0.003887" izz="0.02083"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://robot_description/meshes/visual/link_1.stl"/>
      </geometry>
      <material name="Grey"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://robot_description/meshes/collision/link_1.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- joint 2 -->
  <joint name="iiwa_joint_2" type="revolute">
    <parent link="iiwa_link_1"/>
    <child link="iiwa_link_2"/>
    <origin xyz="0 0 0.19" rpy="1.5708 0 3.1416"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.094" upper="2.094" effort="300" velocity="10"/>
  </joint>

  <link name="iiwa_link_2">
    <inertial>
      <origin xyz="0.0003 0.059 0.042" rpy="0 0 0"/>
      <mass value="3.4821"/>
      <inertia ixx="0.02076" ixy="0" ixz="-0.003626" iyy="0.02179" iyz="0" izz="0.00779"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://robot_description/meshes/visual/link_2.stl"/>
      </geometry>
      <material name="Orange"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://robot_description/meshes/collision/link_2.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- joint 3 -->
  <joint name="iiwa_joint_3" type="revolute">
    <parent link="iiwa_link_2"/>
    <child link="iiwa_link_3"/>
    <origin xyz="0 0.21 0" rpy="1.5708 0 3.1416"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.967" upper="2.967" effort="300" velocity="10"/>
  </joint>

  <link name="iiwa_link_3">
    <inertial>
      <origin xyz="0 0.03 0.13" rpy="0 0 0"/>
      <mass value="4.05623"/>
      <inertia ixx="0.03204" ixy="0" ixz="0" iyy="0.00972" iyz="0.006227" izz="0.03042"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://robot_description/meshes/visual/link_3.stl"/>
      </geometry>
      <material name="Grey"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://robot_description/meshes/collision/link_3.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- joint 4 -->
  <joint name="iiwa_joint_4" type="revolute">
    <parent link="iiwa_link_3"/>
    <child link="iiwa_link_4"/>
    <origin xyz="0 0 0.19" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.094" upper="2.094" effort="300" velocity="10"/>
  </joint>

  <link name="iiwa_link_4">
    <inertial>
      <origin xyz="0 0.067 0.034" rpy="0 0 0"/>
      <mass value="3.4822"/>
      <inertia ixx="0.02178" ixy="0" ixz="0" iyy="0.02075" iyz="-0.003625" izz="0.007785"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://robot_description/meshes/visual/link_4.stl"/>
      </geometry>
      <material name="Orange"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://robot_description/meshes/collision/link_4.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- joint 5 -->
  <joint name="iiwa_joint_5" type="revolute">
    <parent link="iiwa_link_4"/>
    <child link="iiwa_link_5"/>
    <origin xyz="0 0.21 0" rpy="-1.5708 3.1416 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.967" upper="2.967" effort="300" velocity="10"/>
  </joint>

  <link name="iiwa_link_5">
    <inertial>
      <origin xyz="0.0001 0.021 0.076" rpy="0 0 0"/>
      <mass value="2.1633"/>
      <inertia ixx="0.01287" ixy="0" ixz="0" iyy="0.005708" iyz="-0.003946" izz="0.01112"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://robot_description/meshes/visual/link_5.stl"/>
      </geometry>
      <material name="Grey"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://robot_description/meshes/collision/link_5.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- joint 6 -->
  <joint name="iiwa_joint_6" type="revolute">
    <parent link="iiwa_link_5"/>
    <child link="iiwa_link_6"/>
    <origin xyz="0 0.0607 0.19" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.094" upper="2.094" effort="300" velocity="10"/>
  </joint>

  <link name="iiwa_link_6">
    <inertial>
      <origin xyz="0 0.0006 0.0004" rpy="0 0 0"/>
      <mass value="2.3466"/>
      <inertia ixx="0.006509" ixy="0" ixz="0" iyy="0.006259" iyz="0.00031891" izz="0.004527"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://robot_description/meshes/visual/link_6.stl"/>
      </geometry>
      <material name="Orange"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://robot_description/meshes/collision/link_6.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- joint 7 -->
  <joint name="iiwa_joint_7" type="revolute">
    <parent link="iiwa_link_6"/>
    <child link="iiwa_link_7"/>
    <origin xyz="0 0.081 0.0607" rpy="-1.5708 3.1416 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.054" upper="3.054" effort="300" velocity="10"/>
  </joint>

  <link name="iiwa_link_7">
    <inertial>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <mass value="3.129"/>
      <inertia ixx="0.01464" ixy="0.0005912" ixz="0" iyy="0.01465" iyz="0" izz="0.002872"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://robot_description/meshes/visual/link_7.stl"/>
      </geometry>
      <material name="Grey"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://robot_description/meshes/collision/link_7.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- 末端执行器 frame：作为 IK / FK / 规划统一使用的工具坐标系。 -->
  <joint name="iiwa_joint_ee" type="fixed">
    <parent link="iiwa_link_7"/>
    <child link="iiwa_link_ee"/>
    <origin xyz="0 0 0.045"/>
  </joint>

  <link name="iiwa_link_ee">
    <!--
      末端工具 frame 仍保持“零质量虚拟 link”语义。
      这样不会额外改变机械臂动力学，只是让主 URDF 与 Gazebo effort 模型接口更对齐。
    -->
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0"/>
      <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/>
    </inertial>
  </link>

</robot>
